<network>
  <name>{{NET_NAME}}</name>
  <metadata>
    <vadas:tags xmlns:vadas="urn:vadas">
    </vadas:tags>
  </metadata>
  <forward mode='nat'>
    <interface dev='{{INTERFACE}}'/>
  </forward>
  <ip address='{{IP_ADDR}}' netmask='{{NET_MASK}}'>
    <dhcp>
      <range start='{{IP_START}}' end='{{IP_END}}'/>
    </dhcp>
  </ip>
</network>
